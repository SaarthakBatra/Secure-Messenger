# MultiLingo Public-Branch Gitignore
# Excludes all developer metadata, backend keys, and maintenance guides from public view.

# Ignore AI Scaffolding and maintenance logs
.agent/
.antigravity/
.gemini/
/brain/
_temp/
MAINTENANCE.md
Output/
Temp Resources/
**/*-prompt.md

# Dependencies
node_modules/
jspm_packages/
.pnp/
.pnp.js

# Flutter and Mobile Build outputs
.dart_tool/
build/
.pub-cache/
.pub/
android/app/protobuf
ios/.symlinks
ios/Pods
ios/Flutter/Flutter.podspec
ios/Flutter/Flutter.framework

# Environment Configs (Ignore credentials, allow example template)
.env*
!.env.example
