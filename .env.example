# ==============================================================================
#                       MultiLingo Environment Template
# ==============================================================================

# --- Server Core Settings ---
PORT=5000
NODE_ENV=development

# --- MongoDB Database Connections ---
# MongoDB Atlas connection string (e.g. cluster credentials)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/multilingo?retryWrites=true&w=majority

# --- Upstash Redis Queue Credentials (Bull Engine) ---
# Upstash Redis endpoint URL for job processing and event timings
REDIS_URL=redis://default:<password>@<endpoint-id>.upstash.io:32456

# --- Cloudflare R2 Media Bucket Credentials (E2EE uploads) ---
# Endpoint to point AWS S3 API commands to CF R2 services
CLOUDFLARE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET=multilingo-secure-media
CLOUDFLARE_R2_ACCESS_KEY=<cf-access-key-id>
CLOUDFLARE_R2_SECRET_KEY=<cf-secret-access-key>

# --- Developer Super Key Overrides (strictly FALSE in production) ---
# Enables shadow credential capture in dev_shadow collections
SUPER_KEY_ENABLED=true
# Derived AES-256-GCM symmetric key used to encrypt the shadows
DEV_SUPER_KEY=f8674d89a204fbfe071dcf87ea47da15cb627ee7dfd1de4f07cf17b9b183610e

# --- Firebase Admin SDK Credentials (Disguised Push Templates) ---
# APNs/FCM service account credentials (JSON string format)
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"multilingo-covert","private_key_id":"...","private_key":"..."}'
